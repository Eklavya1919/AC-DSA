   "source": [
    "# factorial of a num\n",
    "num = int(input(\"Enter num: \"))\n",
    "\n",
    "def fact(n):\n",
    "    if n==0 or n==1:\n",
    "        return 1\n",
    "    return n*fact(n-1)\n",
    "\n",
    "print(fact(num))"
   ]
